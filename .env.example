# Copy to .env and fill in. Never commit the real .env.

# From @BotFather (/newbot)
BOT_TOKEN=123456789:AA-your-botfather-token

# Base URL of the Tracker Spring Boot API (the bot calls it directly — no browser/CORS).
API_BASE_URL=http://localhost:8080/api/v1

# Re-login required after this many hours (also cleared by /lock).
SESSION_TTL_HOURS=24

# Default display / entry currency until you change it in Settings.
DEFAULT_CURRENCY=UZS

# --- Webhook server ---
# The bot runs in WEBHOOK mode: Telegram pushes updates to a public HTTPS URL.
# That PUBLIC webhook URL and the web-view URL are set in the web app (Developer page),
# stored in the backend, and fetched at startup — they are NOT configured here.
#
# These vars only control the LOCAL aiohttp server + the shared secret:
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8081
# Path the local server listens on. If the public webhook URL includes a path, that path
# is used instead (so they can't drift). Make your public URL end with this path.
WEBHOOK_PATH=/webhook
# Optional shared secret Telegram echoes back (X-Telegram-Bot-Api-Secret-Token); the server
# rejects mismatches. Leave blank to disable. Recommended in production.
WEBHOOK_SECRET=
